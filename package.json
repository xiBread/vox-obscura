		"@vueuse/core": "^9.3.1",
		"@vueuse/nuxt": "^9.3.1",
		"eslint": "^8.25.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-vue": "^9.6.0",
		"nitropack": "^0.6.0",
		"nuxt": "^3.0.0-rc.12",
		"prettier": "^2.7.1",
		"prettier-plugin-tailwindcss": "^0.1.13",
		"tailwindcss": "^3.1.8"
	}
